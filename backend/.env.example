APP_NAME=AI Race Engineer

UDP_HOST=0.0.0.0
UDP_PORT=20777
ENABLE_UDP_LISTENER=true

ENABLE_VOICE=true
ENABLE_COACHING=true
ENABLE_RECORDING=true
VOICE_RATE=185
VOICE_VOLUME=0.85

HISTORY_LIMIT=9000
RECORDING_SAMPLE_HZ=5
DATA_DIR=data/sessions
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Post-race and optional live OpenAI-compatible LLM.
LLM_ENABLED=false
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_TIMEOUT_S=45

# Hands-free two-way radio.
RADIO_ENABLED=true
RADIO_MODE=race
RADIO_WAKE_PHRASES=engineer,race engineer
RADIO_FOLLOWUP_WINDOW_S=20
RADIO_COMMAND_TIMEOUT_S=8

# Leave blank for the Windows default microphone. You can also use a numeric
# device index or a unique part of the device name.
RADIO_INPUT_DEVICE=
RADIO_SAMPLE_RATE=16000
RADIO_FRAME_MS=30
RADIO_VAD_AGGRESSIVENESS=2

# Shorter silence while waiting for the wake phrase, longer silence for the
# actual command/follow-up so normal pauses do not cut the question off.
RADIO_END_SILENCE_MS=700
RADIO_COMMAND_END_SILENCE_MS=1050
RADIO_MIN_SPEECH_MS=250
RADIO_MAX_UTTERANCE_S=15
RADIO_PRE_ROLL_MS=300
RADIO_MIN_CONFIDENCE=0.10

# Optional noise calibration and RMS gate.
RADIO_ENERGY_GATE_ENABLED=true
RADIO_ENERGY_MULTIPLIER=1.8
RADIO_ENERGY_FLOOR_RMS=90
RADIO_NOISE_CALIBRATION_S=5

# Local faster-whisper speech recognition.
RADIO_STT_MODEL=base.en
RADIO_STT_DEVICE=auto
RADIO_STT_COMPUTE_TYPE=int8
RADIO_LANGUAGE=en
RADIO_PRELOAD_STT=true

# Wake acknowledgement: beep, voice, both, or silent.
RADIO_ACK_MODE=beep
RADIO_ACK_TEXT=Listening.
RADIO_ACK_BEEP_FREQUENCY_HZ=920
RADIO_ACK_BEEP_DURATION_MS=95

# Race-style response length.
RADIO_RESPONSE_STYLE=concise
RADIO_MAX_RESPONSE_WORDS=24

# Automatic-call suppression and corner-safe delivery.
RADIO_MIN_AUTO_MESSAGE_INTERVAL_S=10
RADIO_DUPLICATE_COOLDOWN_S=45
RADIO_CATEGORY_COOLDOWN_S=20
RADIO_CRITICAL_OVERRIDE=true
RADIO_CORNER_SAFE_DELIVERY=true
RADIO_PENDING_MESSAGE_MAX_WAIT_S=8

# Keep false for the most reliable initial headset/laptop-mic setup.
RADIO_BARGE_IN_ENABLED=false
RADIO_ECHO_SIMILARITY=0.72
RADIO_TRANSCRIPT_LIMIT=120
RADIO_PROFILE_PATH=%LOCALAPPDATA%/LiveRaceEngineer/radio_profile.json
RADIO_LOG_DIR=%LOCALAPPDATA%/LiveRaceEngineer/radio_logs
RADIO_CONFIRM_CONTROL_ACTIONS=true

# When true, questions not covered by deterministic telemetry tools are sent to
# the OpenAI-compatible endpoint above.
LIVE_LLM_ENABLED=false
LIVE_LLM_MAX_WORDS=32
# ============================================================
# Unified live strategic race engineer
# ============================================================
STRATEGY_ENABLED=true
STRATEGY_EVALUATION_INTERVAL_S=0.75

# Track-specific estimate. Tune this after comparing recorded stops.
STRATEGY_DEFAULT_PIT_LOSS_S=22
STRATEGY_DEFAULT_LAP_TIME_S=90

STRATEGY_CRITICAL_WEAR_PCT=82
STRATEGY_BOX_WEAR_PCT=68
STRATEGY_MARGINAL_FINISH_WEAR_PCT=78
STRATEGY_MAX_FINISH_WEAR_PCT=90
STRATEGY_HOT_TYRE_C=108
STRATEGY_CRITICAL_TYRE_C=115

STRATEGY_ATTACK_GAP_S=1.6
STRATEGY_DEFEND_GAP_S=1.2
STRATEGY_ERS_ATTACK_RESERVE_PCT=28
STRATEGY_ERS_DEFEND_RESERVE_PCT=22
STRATEGY_ERS_HARVEST_TARGET_PCT=55

STRATEGY_AUTO_CALLS=true
STRATEGY_AUTO_BATTLE_CALLS=true
STRATEGY_AUTO_BOX_CALLS=true
STRATEGY_AUTO_ERS_CALLS=true
STRATEGY_AUTO_COACHING_CALLS=true
# Adaptive battle intelligence. The DRS window is a game-rule value; the
# remaining settings control model memory and visual forecast depth.
INTELLIGENCE_DRS_WINDOW_S=1.0
INTELLIGENCE_HISTORY_SECONDS=180
INTELLIGENCE_FORECAST_LAPS=3
INTELLIGENCE_TIMELINE_SIZE=12

INTELLIGENCE_STATE_CONFIDENCE_Z=1.96
