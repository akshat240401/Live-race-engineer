APP_NAME=AI Race Engineer

UDP_HOST=0.0.0.0
UDP_PORT=20777
ENABLE_UDP_LISTENER=true

ENABLE_VOICE=false
ENABLE_COACHING=true
ENABLE_RECORDING=true

VOICE_RATE=185
VOICE_VOLUME=0.85

HISTORY_LIMIT=9000
RECORDING_SAMPLE_HZ=5
DATA_DIR=data/sessions

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional OpenAI-compatible LLM endpoint.
# With this disabled, local RAG and deterministic analysis still work.
LLM_ENABLED=false
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_TIMEOUT_S=45